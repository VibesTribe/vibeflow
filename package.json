{
  "name": "vibeflow",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/dashboard"
  ],
  "scripts": {
    "build": "node scripts/build_dashboard.mjs",
    "lint": "eslint \"src/**/*.ts\" \"apps/**/*.tsx\"",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "generate:manifest": "node scripts/generate_manifest.mjs",
    "compute:keep-delete": "node scripts/compute_keep_delete.mjs --target-tree=docs/system_plan_v5.md --out=docs/keep_delete_v5.md",
    "validate:schemas": "node scripts/validate_json_schemas.mjs",
    "validate:conventions": "node scripts/validate_code_conventions.mjs",
    "state:derive": "node scripts/deriveStateFromEvents.mjs"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "dayjs": "^1.11.11",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3"
  },
  "description": "Vibeflow is a mission-control system that coordinates research, planning, execution, testing, and supervision across LLM agents. The v5 rebuild aligns the repository to the canonical architecture in `docs/system_plan_v5.md` with deterministic manifests, scoped editable regions, and CI enforcement.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VibesTribe/vibeflow.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/VibesTribe/vibeflow/issues"
  },
  "homepage": "https://github.com/VibesTribe/vibeflow#readme"
}
